{
  "scopeName": "source.zyn.injection",
  "injectionSelector": "L:source.rust",
  "patterns": [
    {
      "include": "#zyn-directives"
    },
    {
      "include": "#zyn-interpolation"
    }
  ],
  "repository": {
    "zyn-directives": {
      "patterns": [
        {
          "comment": "@if, @else, @for, @match, @throw, @warn, @note, @help keywords",
          "match": "(@)(if|else|for|match|throw|warn|note|help)\\b",
          "captures": {
            "1": { "name": "keyword.operator.directive.zyn" },
            "2": { "name": "keyword.control.directive.zyn" }
          }
        },
        {
          "comment": "@element_name — element invocation",
          "match": "(@)([a-z][a-z0-9_]*(?:::[a-z][a-z0-9_]*)*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "keyword.operator.directive.zyn" },
            "2": { "name": "entity.name.function.element.zyn" }
          }
        }
      ]
    },
    "zyn-interpolation": {
      "patterns": [
        {
          "comment": "{{ expr | pipe }} interpolation block",
          "begin": "\\{\\s*\\{",
          "end": "\\}\\s*\\}",
          "beginCaptures": {
            "0": { "name": "punctuation.section.interpolation.begin.zyn" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.section.interpolation.end.zyn" }
          },
          "contentName": "meta.interpolation.zyn",
          "patterns": [
            {
              "include": "#pipe-chain"
            },
            {
              "include": "source.rust"
            }
          ]
        }
      ]
    },
    "pipe-chain": {
      "patterns": [
        {
          "comment": "| pipe_name:\"arg\" — pipe with argument",
          "match": "(\\|)\\s*([a-z][a-z0-9_]*)\\s*(:)(\"[^\"]*\")",
          "captures": {
            "1": { "name": "keyword.operator.pipe.zyn" },
            "2": { "name": "entity.name.function.pipe.zyn" },
            "3": { "name": "keyword.operator.pipe-arg.zyn" },
            "4": { "name": "string.quoted.double.zyn" }
          }
        },
        {
          "comment": "| pipe_name — pipe without argument",
          "match": "(\\|)\\s*([a-z][a-z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.operator.pipe.zyn" },
            "2": { "name": "entity.name.function.pipe.zyn" }
          }
        }
      ]
    }
  }
}
